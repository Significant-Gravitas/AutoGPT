# ── Google Apps Script ────────────────────────────────────────────────────────
# The Web App URL from your deployed Code.gs script.
# Used by the React frontend (VITE_ prefix) and the Express server proxy.
VITE_GAS_URL=https://script.google.com/macros/s/AKfycbxIt5jVoSmstOxBh2Ojej3hwSNPHxuWc-gu6CT5-A5iwJEO_8bJYFxg269UJaa0mt09/exec
GAS_URL=https://script.google.com/macros/s/AKfycbxIt5jVoSmstOxBh2Ojej3hwSNPHxuWc-gu6CT5-A5iwJEO_8bJYFxg269UJaa0mt09/exec

# ── Supabase ──────────────────────────────────────────────────────────────────
# Optional: remove if you don't want booking records stored.
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Owner ─────────────────────────────────────────────────────────────────────
# Displayed in the app header ("Book a meeting with {name}")
VITE_OWNER_NAME=Your Name

# ── REST API ──────────────────────────────────────────────────────────────────
# Secret key required in X-Api-Key header for /api/* endpoints.
# Leave empty to disable auth (not recommended in production).
API_KEY=change-me-to-a-strong-secret

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# ── Railway internal ──────────────────────────────────────────────────────────
# Railway sets PORT automatically. Don't override unless testing locally.
# PORT=3000

# ── Server URL (for bot.js) ───────────────────────────────────────────────────
# The public URL of your Railway deployment.
# The Telegram bot calls /api/* internally via this URL.
SERVER_URL=https://your-app.railway.app
