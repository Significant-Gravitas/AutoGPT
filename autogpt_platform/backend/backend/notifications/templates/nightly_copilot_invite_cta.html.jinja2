<div style="font-family: 'Poppins', sans-serif; color: #1F1F20;">
  <!-- Header -->
  <h2
    style="font-size: 24px; line-height: 130%; font-weight: 600; margin-top: 0; margin-bottom: 8px; color: #1F1F20;">
    Your Autopilot beta access is waiting
  </h2>
  <p style="font-size: 14px; line-height: 165%; margin-top: 0; margin-bottom: 24px; color: #505057;">
    You applied to try Autopilot. Here is a tailored example of how it can help once you jump back in.
  </p>

  <!-- Highlight Card -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px;">
    <tr>
      <td
        style="background-color: #7733F5; background: linear-gradient(135deg, #7733F5 0%, #925CF7 100%); border-radius: 12px; padding: 20px 24px;">
        <p
          style="font-size: 14px; line-height: 165%; margin-top: 0; margin-bottom: 0; color: rgba(255,255,255,0.9); font-weight: 500;">
          Autopilot works in the background to handle tasks, surface insights, and take action on your behalf.
        </p>
      </td>
    </tr>
  </table>

  <!-- Body -->
  {{ email_body_html|safe }}

  {% if approval_summary_html %}
  <!-- Approval Callout -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top: 24px; margin-bottom: 8px;">
    <tr>
      <td
        style="background-color: #F1EBFE; border: 1px solid #C0A1FA; border-radius: 12px; padding: 20px 24px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td style="padding-bottom: 12px;">
              <span
                style="display: inline-block; background-color: #7733F5; color: #FFFFFF; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; padding: 4px 10px; border-radius: 999px;">
                Approval needed
              </span>
            </td>
          </tr>
        </table>
        {{ approval_summary_html|safe }}
        <p style="font-size: 14px; line-height: 165%; margin-top: 0; margin-bottom: 0; color: #505057;">
          I thought this was a good idea. If you want it to happen, please hit approve.
        </p>
      </td>
    </tr>
  </table>
  {% endif %}

  <!-- CTA Button -->
  <table cellpadding="0" cellspacing="0" border="0" style="margin-top: 28px;">
    <tr>
      <td align="center"
        style="background-color: #7733F5; border-radius: 999px; mso-padding-alt: 14px 28px;">
        <!--[if mso]>
        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ cta_url }}" style="height:48px;v-text-anchor:middle;width:200px;" arcsize="50%" fillcolor="#7733F5" stroke="f">
          <w:anchorlock/>
          <center style="color:#ffffff;font-family:sans-serif;font-size:15px;font-weight:600;">{{ cta_label }}</center>
        </v:roundrect>
        <![endif]-->
        <!--[if !mso]><!-->
        <a href="{{ cta_url }}"
          style="display: inline-block; padding: 14px 28px; background-color: #7733F5; color: #FFFFFF; text-decoration: none; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 15px; border-radius: 999px; line-height: 1;">
          {{ cta_label }}
        </a>
        <!--<![endif]-->
      </td>
    </tr>
  </table>
</div>
