{
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "plugin:storybook/recommended",
    "plugin:@tanstack/query/recommended"
  ],
  "rules": {
    // Warn on exhaustive-deps to catch stale closures while allowing code-review overrides.
    "react-hooks/exhaustive-deps": "warn",
    // Warn on explicit any to encourage incremental type-safety improvements.
    "@typescript-eslint/no-explicit-any": "warn",
    // Allow unused vars that start with underscore (convention for intentionally unused)
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  }
}
