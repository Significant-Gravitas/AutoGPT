FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi>=0.100.0 \
    "uvicorn[standard]>=0.22.0" \
    anthropic>=0.20.0 \
    "supabase>=2.0.0" \
    pydantic>=2.0.0 \
    python-dotenv>=1.0.0

# Copy only the coaching module and its dependencies
COPY autogpt/ ./autogpt/

# Expose port (Railway / Render set $PORT at runtime)
EXPOSE 8000

CMD ["sh", "-c", "uvicorn autogpt.coaching.api:app --host 0.0.0.0 --port ${PORT:-8000}"]
