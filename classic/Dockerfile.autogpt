# 'dev' or 'release' container build
ARG BUILD_TYPE=dev
ARG PYTHON_VERSION=3.10

# Use an official Python base image from the Docker Hub
FROM python:${PYTHON_VERSION}-slim AS autogpt-base

# Set environment variables early for all layers
ENV PIP_NO_CACHE_DIR=yes \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    POETRY_HOME="/opt/poetry" \
    POETRY_VIRTUALENVS_PATH="/venv" \
    POETRY_VIRTUALENVS_IN_PROJECT=0 \
    POETRY_NO_INTERACTION=1

# Consolidate apt-get updates and installs into single layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium-driver \
    ca-certificates \
    gcc \
    curl \
    jq \
    wget \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install and configure Poetry with version verification
RUN curl -sSL https://install.python-poetry.org | python3 - \
    && poetry --version \
    && poetry config installer.max-workers 10

ENV PATH="$POETRY_HOME/bin:$PATH"

WORKDIR /app/autogpt

# Copy dependency files for better layer caching
COPY original_autogpt/pyproject.toml original_autogpt/poetry.lock ./

# Include forge and frontend as path dependencies
COPY forge/ ../forge
COPY frontend/ ../frontend

# dev build -> include everything
FROM autogpt-base AS autogpt-dev

RUN poetry install --no-cache --no-root \
    && rm -rf $(poetry env info --path)/src

COPY original_autogpt/ ./
RUN mkdir -p ./data

# release build -> include bare minimum
FROM autogpt-base AS autogpt-release

RUN poetry install --no-cache --no-root --without dev \
    && rm -rf $(poetry env info --path)/src

COPY original_autogpt/ ./autogpt
COPY original_autogpt/README.md ./README.md
RUN mkdir -p ./data

# Final stage: select build type and install root package
FROM autogpt-${BUILD_TYPE} AS autogpt

RUN poetry install --only-root

# Set the entrypoint
ENTRYPOINT ["poetry", "run", "autogpt"]
CMD []